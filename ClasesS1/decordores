Decoradores con Argumentos

Un decorador también puede aceptar sus propios argumentos envolviendo la función decoradora en otra función.

def decorador_con_argumentos(mensaje):
def mi_decorador(funcion_original):
def funcion_envolvente(*args, **kwargs):
print(f"{mensaje} - Antes de ejecutar la función.")
resultado = funcion_original(*args, **kwargs)
print(f"{mensaje} - Después de ejecutar la función.")
return resultado
return funcion_envolvente
return mi_decorador

@decorador_con_argumentos("LOG")
def multiplicar(a, b):
return a * b

print(multiplicar(4, 5))
