Ejemplo Práctico: Logger

Un decorador puede ser usado para registrar información sobre las funciones que se ejecutan.

def logger(funcion_original):
import logging
logging.basicConfig(filename=f"{funcion_original.__name__}.log", level=logging.INFO)

def funcion_envolvente(*args, **kwargs):
logging.info(f"Ejecutando con args: {args}, kwargs: {kwargs}")
return funcion_original(*args, **kwargs)
return funcion_envolvente

@logger
def dividir(a, b):
return a / b

dividir(10, 2)
